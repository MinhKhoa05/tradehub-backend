# Database Configuration
DB_ROOT_PASSWORD=YOUR_ROOT_PASSWORD
DB_NAME=game_topup_db
DB_USER=root
DB_PORT_EXTERNAL=3307
DB_PORT_INTERNAL=3306

# API Configuration
API_PORT_EXTERNAL=5000
API_PORT_INTERNAL=8080
ASPNETCORE_ENVIRONMENT=Development

# Connection String
# Local API -> Docker DB: use localhost:3307
# Docker API -> Docker DB: use db:3306
DB_CONNECTION_STRING=Server=127.0.0.1;Port=3307;Database=game_topup_db;User=root;Password=YOUR_ROOT_PASSWORD;SslMode=None;

# JWT Configuration
JWT_KEY=YOUR_SECURE_JWT_KEY_MIN_32_CHARS
JWT_ISSUER=GameTopUp
JWT_AUDIENCE=GameTopUpUsers
JWT_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000
